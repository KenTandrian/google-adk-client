{
  "name": "@kentandrian/google-adk",
  "version": "0.1.6",
  "description": "A TypeScript client library for the Google ADK (Agent Development Kit).",
  "packageManager": "pnpm@10.28.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "prepublishOnly": "pnpm run build",
    "test": "vitest"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai-sdk": {
      "import": "./dist/ai-sdk/index.js",
      "types": "./dist/ai-sdk/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KenTandrian/google-adk-client.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KenTandrian/google-adk-client/issues"
  },
  "homepage": "https://github.com/KenTandrian/google-adk-client#readme",
  "devDependencies": {
    "@assistant-ui/react": "0.14.15",
    "@assistant-ui/react-google-adk": "0.0.15",
    "@biomejs/biome": "2.4.16",
    "@google/adk": "1.2.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "ai": "6.0.201",
    "react": "19.2.7",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@assistant-ui/react": ">=0.14.0",
    "@assistant-ui/react-google-adk": ">=0.0.10",
    "ai": "^6.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@assistant-ui/react": {
      "optional": true
    },
    "@assistant-ui/react-google-adk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
